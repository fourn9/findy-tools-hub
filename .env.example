# ──────────────────────────────────────────────
# フロントエンド (Vite)
# ──────────────────────────────────────────────

# 本番バックエンドURL (Railway にデプロイ後に設定)
# GitHub Actions の Secrets に VITE_API_URL として登録してください
# 例: VITE_API_URL=https://findy-tools-hub.up.railway.app
VITE_API_URL=

# ──────────────────────────────────────────────
# バックエンド (Bun/Hono) — server/.env に置くか直接環境変数で渡す
# ──────────────────────────────────────────────

# サーバーポート (Railway は自動設定)
PORT=3000

# 追加で許可するCORSオリジン (カンマ区切り)
# 例: ALLOWED_ORIGINS=https://example.com,https://staging.example.com
ALLOWED_ORIGINS=
