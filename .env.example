# ──────────────────────────────────────────────
# バックエンド (Bun/Hono)
# このファイルをコピーして .env を作成してください（.env は git 管理外）
# ──────────────────────────────────────────────

# PostgreSQL 接続文字列（必須）
# ローカル例: postgresql://postgres:password@localhost:5432/findy_tools
# Render:  render.yaml の fromDatabase で自動設定されます
DATABASE_URL=postgresql://postgres:password@localhost:5432/findy_tools

# 同期エンドポイントの認証トークン（必須）
# 生成例: openssl rand -hex 32
SYNC_SECRET=change-me-to-a-random-string

# Anthropic API キー（交渉スクリプト生成機能に必要）
# https://console.anthropic.com/ から取得
ANTHROPIC_API_KEY=sk-ant-...

# サーバーポート
PORT=3000

# 追加で許可する CORS オリジン（カンマ区切り、不要なら空のまま）
ALLOWED_ORIGINS=

# ──────────────────────────────────────────────
# フロントエンド (Vite)
# ──────────────────────────────────────────────

# 本番バックエンド URL（GitHub Actions の Secrets に登録してください）
# 例: VITE_API_URL=https://findy-tools-hub-api.onrender.com
VITE_API_URL=
